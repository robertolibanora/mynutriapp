# ========================================
# 🔐 CREDENZIALI ADMIN
# ========================================
ADMIN_PHONE=3491234567
ADMIN_PASSWORD=enrico123
ADMIN_NAME=Enrico Grandi

# ========================================
# 🔑 SECRET KEY
# ========================================
# Genera una SECRET_KEY sicura con:
# python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here-change-this-in-production

# ========================================
# 🗄️ DATABASE MYSQL
# ========================================
# DATABASE_URL viene generato automaticamente da docker-compose.yml
# Non modificare manualmente se usi Docker
# DATABASE_URL=mysql+pymysql://mynutriapp:${MYSQL_PASSWORD}@db:3306/mynutriapp?charset=utf8mb4
DB_TRACK_MODIFICATIONS=False
MYSQL_ROOT_PASSWORD=N0ira2026!
MYSQL_PASSWORD=N0ira2026!

# ========================================
# 🚀 FLASK CONFIGURATION (PRODUZIONE)
# ========================================
FLASK_ENV=production
FLASK_HOST=0.0.0.0
FLASK_PORT=8000
FLASK_DEBUG=False

# ========================================
# 🍪 SESSION CONFIGURATION
# ========================================
# Per HTTPS: imposta SESSION_COOKIE_SECURE=True dopo configurazione SSL
SESSION_COOKIE_SECURE=False
SESSION_COOKIE_HTTPONLY=True
SESSION_COOKIE_SAMESITE=Lax
SESSION_LIFETIME=86400

# ========================================
# 🛡️ CSRF PROTECTION
# ========================================
WTF_CSRF_ENABLED=True
WTF_CSRF_TIME_LIMIT=3600

# ========================================
# 🚦 RATE LIMITING (PRODUZIONE - Abilitato con Redis)
# ========================================
RATELIMIT_ENABLED=True
RATELIMIT_STORAGE_URL=redis://:I0E6TjyZ4wMBqkXNsUsQXBHCZQWf8rfpeyM-X2KQ7lA@redis:6379/0
RATELIMIT_DEFAULT_PER_DAY=200
RATELIMIT_DEFAULT_PER_HOUR=50
RATELIMIT_LOGIN_LIMIT="5 per 15 minutes"
RATELIMIT_CREATE_LIMIT="20 per hour"
RATELIMIT_UPLOAD_LIMIT="10 per hour"

# ========================================
# 🔴 REDIS (Configurazione Docker)
# ========================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=I0E6TjyZ4wMBqkXNsUsQXBHCZQWf8rfpeyM-X2KQ7lA

# ========================================
# 📱 WHATSAPP BUSINESS API (opzionale)
# ========================================
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=3514701562

# ========================================
# 📁 UPLOAD CONFIGURATION
# ========================================
UPLOAD_ROOT=static/uploads
MAX_FILE_SIZE=10

# ========================================
# 📧 NOTIFICHE (Opzionale)
# ========================================
NOTIFICATION_EMAIL_FROM=admin@mynutriapp.com
NOTIFICATION_EMAIL_TO=admin@mynutriapp.com

# ========================================
# 🗄️ MYSQL OTTIMIZZAZIONI (Opzionale)
# ========================================
# Per VPS con più RAM, aumenta il buffer pool
# MYSQL_INNODB_BUFFER_POOL_SIZE=2G
# MYSQL_MAX_CONNECTIONS=300
