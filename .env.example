# ========================================
# 🔐 ADMIN (PRODUZIONE)
# ========================================
ADMIN_PHONE=+39XXXXXXXXXX
ADMIN_NAME=MyNutriApp
ADMIN_PASSWORD_HASH=genera-con-werkzeug

# ========================================
# 🔑 FLASK / SECURITY
# ========================================
FLASK_ENV=production
FLASK_DEBUG=False
SECRET_KEY=genera-con-secrets-token-hex-64-chars
ENCRYPTION_KEY=genera-con-fernet

# ========================================
# 🍪 SESSION
# ========================================
SESSION_COOKIE_SECURE=True
SESSION_COOKIE_HTTPONLY=True
SESSION_COOKIE_SAMESITE=Lax
SESSION_LIFETIME=7200
SESSION_REFRESH_EACH_REQUEST=True
SESSION_PROTECTION=strong

# ========================================
# 🛡️ CSRF
# ========================================
WTF_CSRF_ENABLED=True
WTF_CSRF_TIME_LIMIT=3600

# ========================================
# 🗄️ DATABASE MYSQL (nativo su VPS)
# ========================================
DB_TRACK_MODIFICATIONS=False
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=mynutriapp
DB_USER=mynutriapp
DB_PASSWORD=your-secure-password

MYSQL_ROOT_PASSWORD=your-root-password
MYSQL_PASSWORD=your-secure-password

# ========================================
# 🔴 REDIS (nativo su VPS)
# ========================================
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=your-redis-password

# ========================================
# 🚦 RATE LIMITING
# ========================================
RATELIMIT_ENABLED=True
RATELIMIT_STORAGE_URL=redis://:your-redis-password@127.0.0.1:6379/0
RATELIMIT_DEFAULT_PER_DAY=5000
RATELIMIT_DEFAULT_PER_HOUR=200
RATELIMIT_LOGIN_LIMIT="20 per 15 minutes"
RATELIMIT_CREATE_LIMIT="100 per hour"
RATELIMIT_UPLOAD_LIMIT="50 per hour"

# ========================================
# ⚙️ GUNICORN (systemd)
# ========================================
GUNICORN_BIND=127.0.0.1:8000
GUNICORN_WORKERS=2
GUNICORN_THREADS=2
GUNICORN_TIMEOUT=30

# ========================================
# 📁 UPLOAD
# ========================================
UPLOAD_ROOT=static/uploads
MAX_FILE_SIZE=10

# ========================================
# 🧾 AUDIT LOG
# ========================================
AUDIT_LOG_RETENTION_DAYS=730

# ========================================
# 📱 WHATSAPP - Evolution API (opzionale)
# ========================================
WHATSAPP_ENABLED=False
WHATSAPP_FROM_NAME=MyNutriApp
EVOLUTION_API_URL=http://127.0.0.1:8080
EVOLUTION_API_KEY=your-evolution-api-key
EVOLUTION_INSTANCE=mynutriapp
