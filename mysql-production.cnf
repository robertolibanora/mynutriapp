# ========================================
# 🗄️ CONFIGURAZIONE MYSQL 8.0 PER PRODUZIONE
# MyNutriApp - Ottimizzazioni Performance e Sicurezza
# ========================================

[mysqld]
# ========================================
# 🔧 IDENTIFICAZIONE SERVER
# ========================================
server-id = 1
bind-address = 0.0.0.0
port = 3306

# ========================================
# 📊 CHARSET E COLLATION
# ========================================
character-set-server = utf8mb4
collation-server = utf8mb4_unicode_ci
init_connect = 'SET NAMES utf8mb4'

# ========================================
# 💾 STORAGE ENGINE
# ========================================
default-storage-engine = InnoDB

# ========================================
# 🚀 PERFORMANCE - BUFFER POOL
# ========================================
# Buffer pool: 70-80% della RAM disponibile
# Per VPS con 2GB RAM: ~1.4GB
# Per VPS con 4GB RAM: ~2.8GB
innodb_buffer_pool_size = 1G
innodb_buffer_pool_instances = 4
innodb_buffer_pool_chunk_size = 256M

# ========================================
# 🚀 PERFORMANCE - INNODB
# ========================================
innodb_log_file_size = 256M
innodb_log_buffer_size = 64M
innodb_flush_log_at_trx_commit = 2
innodb_flush_method = O_DIRECT
innodb_file_per_table = 1
innodb_read_io_threads = 4
innodb_write_io_threads = 4
innodb_thread_concurrency = 0

# ========================================
# 🚀 PERFORMANCE - CONNECTION POOL
# ========================================
max_connections = 200
max_connect_errors = 10000
thread_cache_size = 50
table_open_cache = 2000
table_definition_cache = 1400

# ========================================
# 🚀 PERFORMANCE - TEMP TABLES
# ========================================
tmp_table_size = 64M
max_heap_table_size = 64M

# ========================================
# 🚀 PERFORMANCE - SORT E JOIN
# ========================================
sort_buffer_size = 2M
read_buffer_size = 2M
read_rnd_buffer_size = 4M
join_buffer_size = 2M

# ========================================
# 🚀 PERFORMANCE - BINLOG (per backup e replica)
# ========================================
log_bin = /var/lib/mysql/mysql-bin
binlog_format = ROW
binlog_expire_logs_seconds = 604800  # 7 giorni
max_binlog_size = 100M
sync_binlog = 1

# ========================================
# 🔒 SICUREZZA
# ========================================
# Password validation
validate_password.policy = MEDIUM
validate_password.length = 8
validate_password.mixed_case_count = 1
validate_password.number_count = 1
validate_password.special_char_count = 1

# ========================================
# 📝 LOGGING
# ========================================
# General log (disabilitato in produzione per performance)
general_log = 0
general_log_file = /var/lib/mysql/general.log

# Slow query log (abilitato per ottimizzazione)
slow_query_log = 1
slow_query_log_file = /var/lib/mysql/slow-query.log
long_query_time = 2  # Query più lunghe di 2 secondi

# Error log
log_error = /var/lib/mysql/error.log
log_error_verbosity = 2

# ========================================
# 🔧 ALTRE CONFIGURAZIONI
# ========================================
# Timezone
default_time_zone = '+00:00'

# SQL Mode (MySQL 8.0 strict mode)
sql_mode = STRICT_TRANS_TABLES,NO_ZERO_IN_DATE,NO_ZERO_DATE,ERROR_FOR_DIVISION_BY_ZERO,NO_ENGINE_SUBSTITUTION

# Disabilita funzionalità non necessarie
skip_name_resolve = 1
skip_external_locking = 1

# ========================================
# 📊 MONITORING
# ========================================
performance_schema = ON
performance_schema_max_table_instances = 12500

# ========================================
# 🌐 CLIENT CONFIGURATION
# ========================================
[client]
default-character-set = utf8mb4

[mysql]
default-character-set = utf8mb4

[mysqldump]
default-character-set = utf8mb4
single-transaction = 1
quick = 1
